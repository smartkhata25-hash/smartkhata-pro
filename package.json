{
  "name": "smartkhata-desktop",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "electron": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.smartkhata.app",
    "productName": "Smart Khata",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/build/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
